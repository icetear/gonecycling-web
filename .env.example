# Template for production/server environment variables. Copy to `.env` ONLY for a
# real deployment. For LOCAL development do NOT create a `.env` — nothing here is
# needed and safe defaults apply (DEBUG=True, SQLite, app at the domain root).
# Copying this file verbatim sets DEBUG=False (static files then need
# `collectstatic`) and could mount the app under a URL sub-path, so `/` would 404.
# `.env` is in .gitignore.

# REQUIRED in production:
DEBUG=False
# Use a real random value, e.g. generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=set-a-long-random-value-here
# Comma-separated; the public hostname + local addresses (for the
# reverse-proxy host header and local health checks).
DJANGO_ALLOWED_HOSTS=example.com,127.0.0.1,localhost

# URL sub-path behind the reverse proxy (e.g. /gonecycling for
# https://example.com/gonecycling/). Default (commented out) = domain root; only
# set this if you actually serve the app under a sub-path — otherwise `/` 404s.
# GC_BASE_PATH=/gonecycling
# Local port the reverse proxy forwards to (see proxy snippet).
GC_PORT=8071

# Admin/update page (see docs/self-update.md): trusted origins for CSRF.
# Default = https://<DJANGO_ALLOWED_HOSTS>; only override if needed:
# DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com

# Database: if unset, docker-compose.prod.yml uses SQLite on a volume.
# For PostgreSQL instead use e.g.:
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# Optional limits / throttles:
# SYNC_MAX_BLOB_BYTES=8388608
# THROTTLE_ANON=60/min
# THROTTLE_VAULT=120/min

# Brute-force protection: IP block after this many requests with an unknown hash.
# BRUTEFORCE_MAX_FAILURES=3
ADMIN_ALERT_EMAIL=admin@example.com

# Email sending: admin notifications AND user accounts ("Upgrade":
# profile activation, password reset). Default = console (mail only goes to the log).
# For real sending in production set SMTP and then verify with:
#   python manage.py send_test_email YOUR@address.tld
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.org
# EMAIL_PORT=587
# EMAIL_HOST_USER=...
# EMAIL_HOST_PASSWORD=...
# EMAIL_USE_TLS=True
#
# Variant: local Postfix/sendmail on the same host (no login/TLS needed):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=localhost
# EMAIL_PORT=25
# EMAIL_USE_TLS=False
# Note: if the app runs in the Docker container, "localhost" is the container, NOT
# the host Postfix. In that case use e.g. EMAIL_HOST=host.docker.internal (in compose
# extra_hosts: ["host.docker.internal:host-gateway"]) and in Postfix allow the
# container subnets under mynetworks (inet_interfaces=all).
DEFAULT_FROM_EMAIL=gonecycling@example.com

# User accounts: validity period of the mail links in seconds (optional).
# ACCOUNT_ACTIVATION_MAX_AGE=259200      # Activation link (default 3 days)
# ACCOUNT_PASSWORD_RESET_MAX_AGE=3600    # Password reset link (default 1 hour)
